# Gateway / Hermes Agent API server
# The gateway validates requests locally and then forwards every run to the
# remote Hermes Agent API server. Hermes Agent remains the only reasoning and
# orchestration backend for normal spreadsheet assistant behavior.
PORT=8787
GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:8787
HERMES_SERVICE_LABEL=spreadsheet-gateway
HERMES_ENVIRONMENT_LABEL=local-dev
# Required: replace with a long random value; never commit a real secret.
APPROVAL_SECRET=<REPLACE_ME_LONG_RANDOM_SECRET>
MAX_UPLOAD_BYTES=8000000

# Preferred Hermes Agent API server settings
HERMES_AGENT_BASE_URL=http://127.0.0.1:8642/v1
# Optional: leave blank for unauthenticated local demos, otherwise replace locally.
HERMES_API_SERVER_KEY=
HERMES_AGENT_MODEL=hermes-agent

# Optional compatibility aliases
# The gateway still accepts these legacy env names as fallbacks:
# HERMES_BASE_URL=http://127.0.0.1:8642/v1
# HERMES_AGENT_API_KEY=
# HERMES_AGENT_ID=hermes-agent

# Registry metadata for external skills that live outside Hermes core.
SKILL_REGISTRY_PATH=../../extensions/registry/skill-registry.json

# Example external skill sidecars
# These are only needed if your remote Hermes Agent deployment calls the example
# skills in extensions/skills/ from outside Hermes core.
SELECTION_SKILL_PORT=8791
SCREENSHOT_TABLE_SKILL_PORT=8792

# ScreenshotTableExtractionSkill runtime
# Contract-visible extractionMode values exposed to clients are:
# - real
# - demo
# - unavailable
#
# The example sidecar in this repo currently accepts these local env values:
# - real
# - demo
# - disabled   # forces the unavailable/error path at the sidecar layer
#
# Real mode:
#   IMAGE_EXTRACTION_MODE=real
#   REVIEWER_SAFE_MODE=true|false
#   VISION_EXTRACTOR_URL=https://your-vision-bridge.example/extract
#
# Demo mode:
#   IMAGE_EXTRACTION_MODE=demo
#   REVIEWER_SAFE_MODE=false
#   VISION_EXTRACTOR_URL=
#
# Reviewer-safe unavailable path:
#   The host should send reviewer.forceExtractionMode=unavailable.
#   If you also want the local example sidecar to fail closed, set:
#   IMAGE_EXTRACTION_MODE=disabled
#   REVIEWER_SAFE_MODE=true
IMAGE_EXTRACTION_MODE=real
REVIEWER_SAFE_MODE=false
VISION_EXTRACTOR_URL=

# Google Sheets Apps Script script properties
# These are not read from .env. Set them in the Apps Script project settings.
# HERMES_GATEWAY_URL=http://127.0.0.1:8787
# HERMES_CLIENT_VERSION=google-sheets-addon-dev
# HERMES_REVIEWER_SAFE_MODE=false
# HERMES_FORCE_EXTRACTION_MODE=

# Excel task pane runtime toggles
# These are not read from .env. The current task pane reads them from the page
# query string or localStorage for the task pane origin.
# hermesGatewayBaseUrl=http://127.0.0.1:8787
# hermesReviewerSafeMode=false
# hermesForceExtractionMode=
